# Supabase — obtén estos valores en Project Settings > API
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co

SUPABASE_KEY=eyJhbGci...tu_anon_key

# Ventana de datos a descargar en cada ingesta (formato yfinance: 1d, 5d, 1mo, 3mo…)
INGEST_PERIOD=5d

# Hora UTC en que se lanza el job diario (cron: hora y minuto)
INGEST_CRON_HOUR=6
INGEST_CRON_MINUTE=0

# Poner a false en tests / entornos donde no quieras el scheduler
SCHEDULER_ENABLED=true

# LLM — Sesión 6: descubrimiento de exposición indirecta
# Groq compound-beta (web search integrada): https://console.groq.com/keys
GROQ_API_KEY=gsk_...

# Telegram — alertas proactivas (Sesión 8)
# Obtén el token en @BotFather; el chat_id con @userinfobot o enviando un mensaje al bot
TELEGRAM_BOT_TOKEN=123456789:AAxxxxxxxxxxxxxxxxxxxxxxxxx
TELEGRAM_CHAT_ID=123456789
# Umbrales de alerta (opcionales — estos son los valores por defecto)
# FLOW_EXTREME_THRESHOLD=0.7   # |score| mínimo para alerta de flow extremo
# MIN_ALERT_CONFIDENCE=0.4     # confianza mínima numérica para enviar (bajo este valor: registra pero no envía)

# Mensaje-resumen por ciclo en Telegram (Sesión 11) — señal de vida + foto del mercado.
# Se envía SIEMPRE en cada ciclo (haya o no alertas). Ponlo a false para desactivarlo.
# DIGEST_ENABLED=true